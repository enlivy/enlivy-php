# Enlivy PHP SDK - Test Configuration
#
# Copy this file to .env.testing and fill in your credentials.
# This file is used for integration tests.
#
# IMPORTANT: .env.testing is gitignored - never commit real credentials!

# Required for integration tests
ENLIVY_API_KEY="1|your_api_token_here"
ENLIVY_ORGANIZATION_ID="org_xxx"

# Optional: Override API base URL (default: https://api.enlivy.com)
# Use this for local development or staging environments
ENLIVY_API_BASE="http://enlivy_api.test"

# Optional: Enable CRUD tests (creates/modifies/deletes data)
# Only set to "true" for dedicated test organizations!
# ENLIVY_ALLOW_WRITES="true"
